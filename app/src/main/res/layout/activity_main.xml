<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/commanderName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#00FF00"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="COMMANDER: ALI AL-AMMARI" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="#00FF00" />
    </LinearLayout>

    <TextView
        android:id="@+id/sovereignStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:textColor="#00FF00"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:lineSpacingExtra="8dp"
        android:text="[ AEGIS SOVEREIGN CORE v7.2.6 ]\n------------------------------\nSYSTEM: FULLY ENCRYPTED\nAI ENGINE: LOCAL v7.0\nSTEALTH: ACTIVE (GHOST MODE)\nSTATUS: MISSION READY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="8dp"
            android:background="#00FF00" />

        <TextView
            android:id="@+id/footerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#00FF00"
            android:textSize="12sp"
            android:text="QUANTUM SHIELD ACTIVE // VOID-ZERO READY" />
    </LinearLayout>

</RelativeLayout>
